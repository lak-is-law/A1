# Red Gambit - environment variables
#
# Create this file locally to configure the backend engine used by the game.
# Do NOT put real secrets in version control.

# Base URL of your FastAPI engine (POST /move). No trailing /move — we append it.
# Baduk "God" mode uses the same URL (AI_ENGINE_URL + "/move") unless you override below.
# Example for local dev:
#   http://127.0.0.1:8001
AI_ENGINE_URL=http://127.0.0.1:8001

# Optional: override God-mode engine only (defaults to AI_ENGINE_URL + "/move").
# Expected request: game,difficulty,size,to_play,komi,board,time_ms
# Expected response: { move: "r,c" | "pass", depth?: number, nodes?: number, score?: number }
# BADUK_GOD_API_URL=https://your-strong-go-engine.example.com/move
# Optional explicit health endpoint (defaults to replacing /move -> /health).
# BADUK_GOD_HEALTH_URL=https://your-strong-go-engine.example.com/health
# BADUK_GOD_API_KEY=your-secret-key

